{
  "installCommand": "npm install",
  "buildCommand": "NITRO_PRESET=vercel npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}